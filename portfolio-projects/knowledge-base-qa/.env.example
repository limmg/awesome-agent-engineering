# 必填：智谱 API Key（https://open.bigmodel.cn/）
ZHIPUAI_API_KEY=your-key-here

# 以下全部可选，默认值见 src/kb_qa/config.py
# ANSWER_MODEL=glm-4
# REWRITE_MODEL=glm-4-flash
# ENABLE_RERANK=true
# ENABLE_MULTI_QUERY=false
# BM25_WEIGHT=0.4
# VECTOR_WEIGHT=0.6
# RETRIEVE_K=8
# FINAL_K=4
# CHUNK_SIZE=500
# CHUNK_OVERLAP=80
# PORT=8001

# 可观测性（LLMOps L01）：日志格式与级别
# LOG_JSON=true        # true=JSON 行（生产/机器消费）；false=人类可读文本（开发）
# LOG_LEVEL=INFO       # 调到 DEBUG 可看检索分词等中间状态
