# 必填：智谱 API Key（https://open.bigmodel.cn/）
ZHIPUAI_API_KEY=your-key-here

# 以下全部可选，默认值见 src/kb_qa/config.py
# ANSWER_MODEL=glm-4
# REWRITE_MODEL=glm-4-flash
# ENABLE_RERANK=true
# ENABLE_MULTI_QUERY=false
# BM25_WEIGHT=0.4
# VECTOR_WEIGHT=0.6
# RETRIEVE_K=8
# FINAL_K=4
# CHUNK_SIZE=500
# CHUNK_OVERLAP=80
# PORT=8001

# 可观测性（LLMOps L01）：日志格式与级别
# LOG_JSON=true        # true=JSON 行（生产/机器消费）；false=人类可读文本（开发）
# LOG_LEVEL=INFO       # 调到 DEBUG 可看检索分词等中间状态

# 全链路追踪（LLMOps L02 · Langfuse）—— 全部默认关闭，不配则降级打印 trace 树
# 启用步骤：1) docker compose -f docker-compose.langfuse.yml up -d
#          2) http://localhost:3000 建项目拿 key
#          3) pip install langfuse
#          4) 填下面四项后重启服务
# LANGFUSE_ENABLED=false
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# 线上评估闭环（LLMOps L03）：真实问答抽样跑 ragas，低分进 review_queue
# EVAL_SAMPLE_RATE=0.05      # 抽样率（生产典型 5%；内测/演示调高到 0.3~1.0）
# EVAL_SCORE_THRESHOLD=0.5   # faithfulness/relevancy 低于此即低分入队
# EVAL_REVIEW_QUEUE_PATH=eval/review_queue.jsonl
