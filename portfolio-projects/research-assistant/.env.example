# ── 必填 ──────────────────────────────────────────────────
# 智谱 API Key（去 https://open.bigmodel.cn/ 控制台获取）
ZHIPUAI_API_KEY=your-zhipuai-api-key-here

# ── LLM 模型（可选，有默认值）──────────────────────────────
# 决策/写作模型（贵但聪明）
SMART_MODEL=glm-4
# 执行模型（免费快，用于并行检索）
FAST_MODEL=glm-4-flash
LLM_TEMPERATURE=0.3

# ── 并行研究参数（可选）────────────────────────────────────
# 把主题拆成几个子问题（=并行研究员数量）
NUM_SUBTOPICS=3
# web_search 并发上限（防 DuckDuckGo QPS 封禁）
MAX_CONCURRENT_SEARCH=5
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT=15

# ── 审稿回路（阶段 2，可选）────────────────────────────────
# 报告最多重写次数（防死循环）
MAX_REWRITES=3

# ── 持久化（阶段 2，可选）──────────────────────────────────
# SqliteSaver 数据库路径；为空用 InMemorySaver（重启即丢）
SQLITE_DB_PATH=research_assistant.db

# ── 服务（阶段 3，可选）────────────────────────────────────
HOST=0.0.0.0
PORT=8000
